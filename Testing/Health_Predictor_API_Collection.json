        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"patient_{{$timestamp}}\",\n  \"email\": \"patient_{{$timestamp}}@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"password2\": \"SecurePass123!\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"user_type\": \"patient\",\n  \"phone_number\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{api_base}}/accounts/register/",
              "host": ["{{api_base}}"],
              "path": ["accounts", "register", ""]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Patient registration successful', function() {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "    let responseData = pm.response.json();",
                  "    pm.expect(responseData.token).to.exist;",
                  "    pm.expect(responseData.user.user_type).to.equal('patient');",
                  "    pm.environment.set('patient_token', responseData.token);",
                  "    pm.environment.set('patient_id', responseData.user.id);",
                  "});"
                ]
              }
            }
          ]
        },
